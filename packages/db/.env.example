# Neon POOLED connection (host contains "-pooler") — used by the runtime db client.
DATABASE_URL="postgresql://user:password@ep-xxxx-pooler.region.aws.neon.tech/fabel?sslmode=require"

# Neon DIRECT connection (no "-pooler") — used ONLY by drizzle-kit migrations.
DATABASE_URL_UNPOOLED="postgresql://user:password@ep-xxxx.region.aws.neon.tech/fabel?sslmode=require"
